# Copy to .env.local for development. In production, set these in Amplify Hosting > Environment variables.
# All values come out of `cdk deploy` outputs in the EaglesAuctionStack.

NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_APPSYNC_URL=
NEXT_PUBLIC_APPSYNC_REGION=us-east-1

# Used by scripts/seed-items.ts only (server-side, never shipped to the browser).
AWS_PROFILE=eagles-autism-project
AUCTION_ITEMS_TABLE=
